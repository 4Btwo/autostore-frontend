rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ═══════════════════════════════════════════════════════════════
    // HELPER FUNCTIONS
    // ═══════════════════════════════════════════════════════════════

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    function isAdmin() {
      return isAuthenticated() && request.auth.token.isAdmin == true;
    }

    function isValidString(field, minLen, maxLen) {
      return field is string && field.size() >= minLen && field.size() <= maxLen;
    }

    // Retorna os campos que mudaram entre o documento antigo e o novo
    function changedKeys() {
      return request.resource.data.diff(resource.data).affectedKeys();
    }

    // ═══════════════════════════════════════════════════════════════
    // USUÁRIOS
    // ═══════════════════════════════════════════════════════════════
    match /users/{uid} {
      allow read: if isOwner(uid) || isAdmin();

      allow create: if isOwner(uid)
        && isValidString(request.resource.data.email, 3, 200)
        && (!("isAdmin"   in request.resource.data) || request.resource.data.isAdmin   == false)
        && (!("isPremium" in request.resource.data) || request.resource.data.isPremium == false);

      allow update: if (
          isOwner(uid)
          && !("isAdmin"        in changedKeys())
          && !("isPremium"      in changedKeys())
          && !("sellerVerified" in changedKeys())
        )
        || isAdmin();

      allow delete: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════════
    // CATÁLOGO — leitura pública, escrita apenas admin
    // ═══════════════════════════════════════════════════════════════
    match /vehicles/{vehicleId} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    match /models/{modelId} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    match /brands/{brandId} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    match /categories/{categoryId} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════════
    // MASTER PARTS — Layer 3 (Catálogo Interno)
    // - Leitura pública (necessário para o marketplace)
    // - Escrita apenas via Admin SDK no backend (admin token)
    // - Vendedores interagem apenas via API, nunca diretamente
    // ═══════════════════════════════════════════════════════════════
    match /masterParts/{partId} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════════
    // COMPATIBILIDADES
    // ═══════════════════════════════════════════════════════════════
    match /compatibilities/{compatId} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════════
    // MARKETPLACE PARTS — Layer 4 (Anúncios)
    //
    // ENFORCEMENT ESTRITO DO CATÁLOGO:
    //   ✅ masterPartId é OBRIGATÓRIO e IMUTÁVEL após criação
    //   ✅ sellerConfirmedCompatibility deve ser TRUE no create
    //   ✅ price: número > 0
    //   ✅ stock: inteiro >= 0
    //   ✅ condition: apenas "new" ou "used"
    //   ✅ Apenas campos conhecidos são permitidos (hasOnly)
    //   ✅ masterPartId / source / confidenceScore são IMUTÁVEIS
    //   ✅ Vendedor só pode alterar: price, stock, active, sellerNotes, images
    // ═══════════════════════════════════════════════════════════════
    match /marketplaceParts/{partId} {

      // ── Leitura ──────────────────────────────────────────────────
      allow read: if resource.data.active == true;
      allow read: if isAdmin();
      allow read: if isAuthenticated()
        && resource.data.sellerId == request.auth.uid;

      // ── Criação ──────────────────────────────────────────────────
      allow create: if isAuthenticated()

        // Propriedade: sellerId deve ser o próprio usuário
        && request.resource.data.sellerId == request.auth.uid

        // Integridade do catálogo: masterPartId obrigatório e não-vazio
        && request.resource.data.masterPartId is string
        && request.resource.data.masterPartId.size() > 0

        // Vendedor deve confirmar compatibilidade explicitamente
        && request.resource.data.sellerConfirmedCompatibility == true

        // Preço: número positivo
        && request.resource.data.price is number
        && request.resource.data.price > 0

        // Estoque: inteiro não-negativo
        && request.resource.data.stock is int
        && request.resource.data.stock >= 0

        // Condição: apenas "new" ou "used"
        && request.resource.data.condition in ["new", "used"]

        // Moderação: novos anúncios sempre começam como "pending"
        && request.resource.data.moderationStatus == "pending"

        // Schema enforcement: somente campos conhecidos são permitidos
        && request.resource.data.keys().hasOnly([
          "sellerId",
          "masterPartId",
          "price",
          "stock",
          "condition",
          "state",
          "sellerNotes",
          "images",
          "sellerConfirmedCompatibility",
          "confidenceScore",
          "confidenceLabel",
          "confidenceBreakdown",
          "source",
          "active",
          "moderationStatus",
          "approvedAt",
          "rejectedAt",
          "rejectionReason",
          "createdAt",
          "updatedAt"
        ]);

      // ── Atualização ───────────────────────────────────────────────
      allow update: if isAdmin()
        || (
          isAuthenticated()
          && resource.data.sellerId == request.auth.uid

          // Campos imutáveis: não podem ser alterados após criação
          && !("masterPartId"                in changedKeys())
          && !("source"                      in changedKeys())
          && !("confidenceScore"             in changedKeys())
          && !("confidenceLabel"             in changedKeys())
          && !("confidenceBreakdown"         in changedKeys())
          && !("sellerId"                    in changedKeys())
          && !("sellerConfirmedCompatibility" in changedKeys())
          && !("createdAt"                   in changedKeys())

          // Campos de moderação: somente admin pode alterar
          && !("moderationStatus" in changedKeys())
          && !("approvedAt"       in changedKeys())
          && !("rejectedAt"       in changedKeys())
          && !("rejectionReason"  in changedKeys())

          // Vendedor só pode alterar esses campos
          && changedKeys().hasOnly([
            "price",
            "stock",
            "active",
            "sellerNotes",
            "images",
            "updatedAt"
          ])

          // Revalida price se foi alterado
          && (
            !("price" in changedKeys())
            || (request.resource.data.price is number && request.resource.data.price > 0)
          )

          // Revalida stock se foi alterado
          && (
            !("stock" in changedKeys())
            || (request.resource.data.stock is int && request.resource.data.stock >= 0)
          )
        );

      allow delete: if isAdmin()
        || (isAuthenticated() && resource.data.sellerId == request.auth.uid);
    }

    // ═══════════════════════════════════════════════════════════════
    // PEDIDOS
    // ═══════════════════════════════════════════════════════════════
    match /orders/{orderId} {
      allow read: if isAuthenticated()
        && resource.data.buyerId == request.auth.uid;

      allow read: if isAuthenticated()
        && request.auth.uid in resource.data.sellerIds;

      allow read: if isAdmin();

      allow create: if isAuthenticated();

      allow update: if isAuthenticated()
        && (
          resource.data.buyerId == request.auth.uid
          || request.auth.uid in resource.data.sellerIds
          || isAdmin()
        );

      allow delete: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════════
    // AVALIAÇÕES
    // ═══════════════════════════════════════════════════════════════
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isAuthenticated()
        && request.resource.data.buyerId == request.auth.uid
        && request.resource.data.rating >= 1
        && request.resource.data.rating <= 5;
      allow update, delete: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════════
    // NOTIFICAÇÕES
    // ═══════════════════════════════════════════════════════════════
    match /notifications/{notifId} {
      allow read: if isAuthenticated()
        && resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated()
        && resource.data.userId == request.auth.uid
        && changedKeys().hasOnly(["read"]);
      allow create, delete: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════════
    // CACHE DE CHASSI
    // ═══════════════════════════════════════════════════════════════
    match /chassiCache/{vin} {
      allow read:  if isAuthenticated();
      allow write: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════════
    // BLOQUEIO PADRÃO — nega tudo que não foi explicitamente permitido
    // ═══════════════════════════════════════════════════════════════
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
