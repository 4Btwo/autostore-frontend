rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Funções auxiliares ──────────────────────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    function isAdmin() {
      return isAuthenticated() && request.auth.token.isAdmin == true;
    }

    function isValidString(field, minLen, maxLen) {
      return field is string && field.size() >= minLen && field.size() <= maxLen;
    }

    // ─── Usuários ────────────────────────────────────────────────────────────
    match /users/{uid} {
      allow read: if isOwner(uid) || isAdmin();

      // CORREÇÃO: campo isAdmin e isPremium podem não existir no documento
      // (Google login e cadastro por email não enviam esses campos)
      // Regra anterior: request.resource.data.isAdmin == false → null != false → NEGADO
      allow create: if isOwner(uid)
        && isValidString(request.resource.data.email, 3, 200)
        && (!("isAdmin"   in request.resource.data) || request.resource.data.isAdmin   == false)
        && (!("isPremium" in request.resource.data) || request.resource.data.isPremium == false);

      // Atualização: owner pode alterar qualquer campo exceto os protegidos
      allow update: if (isOwner(uid)
          && !("isAdmin"        in request.resource.data.diff(resource.data).affectedKeys())
          && !("isPremium"      in request.resource.data.diff(resource.data).affectedKeys())
          && !("sellerVerified" in request.resource.data.diff(resource.data).affectedKeys()))
        || isAdmin();

      allow delete: if isAdmin();
    }

    // ─── Veículos ────────────────────────────────────────────────────────────
    match /vehicles/{vehicleId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /models/{modelId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /brands/{brandId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ─── Peças mestras (catálogo) ─────────────────────────────────────────────
    match /masterParts/{partId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ─── Compatibilidades ────────────────────────────────────────────────────
    match /compatibilities/{compatId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ─── Marketplace ─────────────────────────────────────────────────────────
    match /marketplaceParts/{partId} {
      // Leitura pública: aprovados OU pendentes e ativos
      allow read: if resource.data.active == true;
      // Admin lê tudo
      allow read: if isAdmin();
      // Vendedor vê seus próprios anúncios independente de status
      allow read: if isAuthenticated()
        && resource.data.sellerId == request.auth.uid;

      // CORREÇÃO: removido "active == false" — o backend cria com active: true
      // A visibilidade pública é controlada por moderationStatus, não por active
      allow create: if isAuthenticated()
        && request.resource.data.sellerId == request.auth.uid
        && request.resource.data.price > 0
        && request.resource.data.stock >= 0
        && request.resource.data.moderationStatus == "pending";

      // CORREÇÃO: vendedor pode alterar active (desativar/reativar próprio anúncio)
      // mas não pode alterar moderationStatus nem approvedBy
      allow update: if isAdmin()
        || (isAuthenticated()
          && resource.data.sellerId == request.auth.uid
          && !("moderationStatus" in request.resource.data.diff(resource.data).affectedKeys())
          && !("approvedBy"       in request.resource.data.diff(resource.data).affectedKeys()));

      allow delete: if isAdmin()
        || (isAuthenticated() && resource.data.sellerId == request.auth.uid);
    }

    // ─── Pedidos ─────────────────────────────────────────────────────────────
    match /orders/{orderId} {
      allow read: if isAuthenticated()
        && resource.data.buyerId == request.auth.uid;

      allow read: if isAuthenticated()
        && request.auth.uid in resource.data.sellerIds;

      allow read: if isAdmin();

      allow create: if isAuthenticated();

      allow update: if isAuthenticated()
        && (resource.data.buyerId == request.auth.uid
          || request.auth.uid in resource.data.sellerIds
          || isAdmin());

      allow delete: if isAdmin();
    }

    // ─── Avaliações ──────────────────────────────────────────────────────────
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isAuthenticated()
        && request.resource.data.buyerId == request.auth.uid
        && request.resource.data.rating >= 1
        && request.resource.data.rating <= 5;
      allow update, delete: if isAdmin();
    }

    // ─── Notificações ────────────────────────────────────────────────────────
    match /notifications/{notifId} {
      allow read: if isAuthenticated()
        && resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated()
        && resource.data.userId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["read"]);
      allow create, delete: if isAdmin();
    }

    // ─── Cache de chassi ─────────────────────────────────────────────────────
    match /chassiCache/{vin} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ─── Bloqueio geral ───────────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
